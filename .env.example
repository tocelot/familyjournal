# Database (Neon Postgres - provisioned via Vercel or Neon dashboard)
POSTGRES_URL=              # Neon Postgres connection string

# Blob Storage
BLOB_READ_WRITE_TOKEN=     # Vercel Blob token (auto-set by Vercel)

# Auth
SITE_PASSWORD_HASH=        # bcrypt hash of the shared family password (generate with: npx bcryptjs hash "yourpassword")
SESSION_SECRET=            # Secret for signing session cookies (random 64-char string)
SESSION_MAX_AGE=2592000    # Session duration in seconds (default: 30 days)

# API
OPENCLAW_API_KEY=          # API key for OpenClaw bot to authenticate

# App
NEXT_PUBLIC_APP_NAME="Growing Up Journal"
